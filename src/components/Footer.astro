---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="footer-logo">CR2S</span>
        <p class="footer-tagline">Centre de Rééducation<br/>Sport & Santé</p>
        <p class="footer-desc">
          Depuis plus de 20 ans, nous accompagnons les sportifs amateurs et professionnels dans leur rééducation au coeur de Nantes.
        </p>
      </div>

      <div class="footer-col">
        <h4>Navigation</h4>
        <a href="/">Accueil</a>
        <a href="/services">Services</a>
        <a href="/equipe">Équipe</a>
        <a href="/equipements">Équipements</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <a href="/services#kinesitherapie">Kinésithérapie</a>
        <a href="/services#osteopathie">Ostéopathie</a>
        <a href="/services#podologie">Podologie</a>
        <a href="/services#reeducation">Rééducation sportive</a>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <p>18 bis, rue Fouré</p>
        <p>44000 Nantes</p>
        <a href="tel:0240890014" class="footer-phone">02 40 89 00 14</a>
        <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent footer-cta">
          Prendre rendez-vous
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} CR2S - Centre de Rééducation Sport & Santé. Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary-dark);
    color: rgba(255, 255, 255, 0.7);
    padding: 4rem 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 2.5rem;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
  }

  .footer-tagline {
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    margin-top: 0.25rem;
    line-height: 1.4;
  }

  .footer-desc {
    margin-top: 1rem;
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer-col h4 {
    color: white;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .footer-col a,
  .footer-col p {
    display: block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    padding: 0.25rem 0;
    transition: var(--transition);
  }

  .footer-col a:hover {
    color: var(--color-accent);
  }

  .footer-phone {
    font-weight: 600;
    color: white !important;
    margin-top: 0.5rem;
  }

  .footer-cta {
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    display: inline-flex;
  }

  .footer-bottom {
    margin-top: 3rem;
    padding: 1.25rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 840px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 540px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
