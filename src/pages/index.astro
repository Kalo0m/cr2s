---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Accueil">
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-content">
      <span class="hero-tag">Centre de rééducation a Nantes</span>
      <h1>Votre santé,<br/>notre expertise.</h1>
      <p class="hero-text">
        Depuis plus de 20 ans, le CR2S accompagne les sportifs amateurs et professionnels
        dans leur rééducation avec une équipe de 13 praticiens spécialisés.
      </p>
      <div class="hero-actions">
        <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent">
          Prendre rendez-vous
        </a>
        <a href="/services" class="btn btn-outline">Découvrir nos services</a>
      </div>
    </div>
    <div class="hero-bar">
      <div class="container hero-stats">
        <div class="stat">
          <span class="stat-number">20+</span>
          <span class="stat-label">ans d'expérience</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">13</span>
          <span class="stat-label">praticiens</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">350 m²</span>
          <span class="stat-label">d'espace dédié</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">3</span>
          <span class="stat-label">spécialités</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Nos expertises</h2>
        <p>Une prise en charge complète pour votre rééducation et votre bien-être</p>
      </div>
      <div class="grid-3">
        <a href="/services#kinesitherapie" class="card service-card">
          <span class="service-num">01</span>
          <h3>Kinésithérapie</h3>
          <p>Éducation thérapeutique, exercices actifs, massages et étirements pour rétablir vos capacités fonctionnelles.</p>
          <span class="card-link">En savoir plus &rarr;</span>
        </a>

        <a href="/services#osteopathie" class="card service-card">
          <span class="service-num">02</span>
          <h3>Ostéopathie</h3>
          <p>Approche globale identifiant et traitant les restrictions de mobilité affectant les structures du corps.</p>
          <span class="card-link">En savoir plus &rarr;</span>
        </a>

        <a href="/services#podologie" class="card service-card">
          <span class="service-num">03</span>
          <h3>Podologie</h3>
          <p>Spécialiste des pathologies sportives du pied et du membre inférieur. Semelles sur mesure.</p>
          <span class="card-link">En savoir plus &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- À PROPOS -->
  <section class="section about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <span class="tag">Le centre</span>
          <h2>Un espace dédié à votre rééducation</h2>
          <p>
            Situé au coeur de Nantes, le CR2S dispose d'un espace de <strong>350 m²</strong>
            équipé des technologies les plus récentes : plateau technique de 85 m²,
            balnéothérapie avec piscine de 28 m², appareils de musculation et cardio,
            ondes de choc, cryothérapie et échographie.
          </p>
          <p>
            Notre équipe pluridisciplinaire de <strong>13 praticiens</strong> — kinésithérapeutes,
            ostéopathes et podologues — vous accompagne de la blessure jusqu'au retour sur le terrain.
          </p>
          <a href="/equipements" class="btn btn-outline">Nos équipements</a>
        </div>
        <div class="about-highlights">
          <div class="highlight">
            <span class="highlight-label">Accessibilité</span>
            <span class="highlight-value">Rez-de-chaussée, PMR</span>
          </div>
          <div class="highlight">
            <span class="highlight-label">Balnéothérapie</span>
            <span class="highlight-value">Piscine 4 x 7 m</span>
          </div>
          <div class="highlight">
            <span class="highlight-label">Plateau technique</span>
            <span class="highlight-value">85 m² équipés</span>
          </div>
          <div class="highlight">
            <span class="highlight-label">Technologies</span>
            <span class="highlight-value">Ondes de choc, cryo, écho</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-content">
      <h2>Prêt à reprendre le sport ?</h2>
      <p>Prenez rendez-vous en ligne ou appelez-nous au 02 40 89 00 14.</p>
      <div class="cta-actions">
        <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent">
          Réserver en ligne
        </a>
        <a href="tel:0240890014" class="btn cta-phone">
          02 40 89 00 14
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-top: 64px;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 640px;
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .hero-tag {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
  }

  .hero-text {
    font-size: 1.1rem;
    color: var(--color-text-light);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-bar {
    background: var(--color-primary);
    padding: 1.75rem 0;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.2rem;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.15);
  }

  /* SERVICES */
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .service-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    margin-bottom: 0.6rem;
  }

  .service-card p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    line-height: 1.7;
    flex: 1;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 1.25rem;
    transition: var(--transition);
  }

  .service-card:hover .card-link {
    color: var(--color-accent);
  }

  /* ABOUT */
  .about-section {
    background: var(--color-bg-alt);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .tag {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  .about-text h2 {
    margin-bottom: 1.25rem;
  }

  .about-text p {
    color: var(--color-text-light);
    margin-bottom: 1rem;
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .about-text .btn {
    margin-top: 0.75rem;
  }

  .about-highlights {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 0.5rem;
  }

  .highlight {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .highlight:first-child {
    padding-top: 0;
  }

  .highlight:last-child {
    border-bottom: none;
  }

  .highlight-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .highlight-value {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  /* CTA */
  .cta-section {
    background: var(--color-primary);
    padding: 5rem 0;
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    color: white;
    margin-bottom: 0.75rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-phone {
    color: white;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    font-weight: 600;
    padding: 0.8rem 1.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    transition: var(--transition);
  }

  .cta-phone:hover {
    border-color: white;
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 840px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-stats {
      gap: 1.5rem;
    }

    .stat-divider {
      display: none;
    }
  }

  @media (max-width: 540px) {
    .hero-stats {
      flex-wrap: wrap;
      gap: 1.25rem;
    }

    .stat {
      min-width: 40%;
    }
  }
</style>
