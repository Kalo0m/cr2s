---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Accueil">
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-content">
      <h1>Votre santé,<br/>notre expertise.</h1>
      <p class="hero-text">
        Depuis plus de 20 ans, le CR2S accompagne les sportifs amateurs et professionnels
        dans leur rééducation avec une équipe de 13 praticiens spécialisés à Nantes.
      </p>
      <div class="hero-actions">
        <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent">
          Prendre rendez-vous
        </a>
        <a href="/services" class="btn btn-outline">Découvrir nos services</a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-num">20+</span>
          <span class="stat-label">ans d'expérience</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">13</span>
          <span class="stat-label">praticiens</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">350 m²</span>
          <span class="stat-label">d'espace dédié</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">3</span>
          <span class="stat-label">spécialités</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Nos expertises</h2>
        <p>Une prise en charge complète pour votre rééducation</p>
      </div>
      <div class="grid-3">
        <a href="/services#kinesitherapie" class="card service-card">
          <span class="service-num">01</span>
          <h3>Kinésithérapie</h3>
          <p>Éducation thérapeutique, exercices actifs, massages et étirements pour rétablir vos capacités fonctionnelles.</p>
          <span class="card-arrow">&rarr;</span>
        </a>

        <a href="/services#osteopathie" class="card service-card">
          <span class="service-num">02</span>
          <h3>Ostéopathie</h3>
          <p>Approche globale identifiant et traitant les restrictions de mobilité du corps.</p>
          <span class="card-arrow">&rarr;</span>
        </a>

        <a href="/services#podologie" class="card service-card">
          <span class="service-num">03</span>
          <h3>Podologie</h3>
          <p>Pathologies sportives du pied et du membre inférieur. Semelles orthopédiques sur mesure.</p>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- À PROPOS -->
  <section class="section about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>Un espace dédié à votre rééducation</h2>
          <p>
            Situé au coeur de Nantes, le CR2S dispose d'un espace de <strong>350 m²</strong>
            avec plateau technique de 85 m², piscine de balnéothérapie, appareils de musculation
            et cardio, ondes de choc, cryothérapie et échographie.
          </p>
          <p>
            Notre équipe de <strong>13 praticiens</strong> — kinésithérapeutes,
            ostéopathes et podologues — vous accompagne de la blessure jusqu'au retour sur le terrain.
          </p>
          <a href="/equipements" class="btn btn-outline">Nos équipements</a>
        </div>
        <div class="about-details">
          <div class="detail-row">
            <span class="detail-label">Accessibilité</span>
            <span class="detail-value">Rez-de-chaussée, PMR</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Balnéothérapie</span>
            <span class="detail-value">Piscine 4 x 7 m</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Plateau technique</span>
            <span class="detail-value">85 m² équipés</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Technologies</span>
            <span class="detail-value">Ondes de choc, cryo, écho</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-content">
      <h2>Prêt à reprendre le sport ?</h2>
      <p>Prenez rendez-vous en ligne ou appelez-nous.</p>
      <div class="cta-actions">
        <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent">
          Réserver en ligne
        </a>
        <a href="tel:0240890014" class="btn cta-phone">
          02 40 89 00 14
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 10rem 0 5rem;
  }

  .hero-content {
    max-width: 580px;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
  }

  .hero-text {
    font-size: 1.05rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* STATS */
  .stats-section {
    background: var(--color-primary);
    padding: 2.5rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-num {
    font-size: 1.6rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.3rem;
  }

  /* SERVICES */
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .service-num {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .service-card h3 {
    margin-bottom: 0.5rem;
  }

  .service-card p {
    color: var(--color-text-light);
    font-size: 0.88rem;
    line-height: 1.7;
    flex: 1;
  }

  .card-arrow {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
    transition: var(--transition);
  }

  .service-card:hover .card-arrow {
    color: var(--color-accent);
  }

  /* ABOUT */
  .about-section {
    background: var(--color-bg-alt);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-text h2 {
    margin-bottom: 1rem;
  }

  .about-text p {
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .about-text .btn {
    margin-top: 1rem;
  }

  .about-details {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .detail-row:last-child {
    border-bottom: none;
  }

  .detail-label {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .detail-value {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  /* CTA */
  .cta-section {
    background: var(--color-bg-warm);
    padding: 5rem 0;
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 1.75rem;
  }

  .cta-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-phone {
    color: var(--color-text);
    border: 1.5px solid var(--color-border);
    background: var(--color-white);
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    transition: var(--transition);
  }

  .cta-phone:hover {
    border-color: var(--color-primary);
  }

  @media (max-width: 840px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 540px) {
    .hero {
      padding: 8rem 0 3rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
