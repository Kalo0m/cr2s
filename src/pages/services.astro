---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services" description="Kinésithérapie, ostéopathie, podologie et rééducation sportive au CR2S Nantes.">
  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-content">
        <div class="hero-badge">Nos expertises</div>
        <h1>Des soins adaptés<br/>à chaque <span class="text-accent">besoin</span></h1>
        <p>Une prise en charge complète par notre équipe pluridisciplinaire de kinésithérapeutes, ostéopathes et podologues.</p>
      </div>
    </div>
  </section>

  <!-- KINÉSITHÉRAPIE -->
  <section class="section service-detail" id="kinesitherapie">
    <div class="container">
      <div class="service-detail-grid">
        <div class="service-detail-content">
          <div class="service-number">01</div>
          <h2>Kinésithérapie</h2>
          <p class="service-intro">
            La kinésithérapie est un traitement basé sur le mouvement, visant à rétablir les capacités
            fonctionnelles et améliorer la qualité de vie du patient.
          </p>
          <div class="service-list">
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Éducation thérapeutique du patient</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Exercices actifs et rééducation fonctionnelle</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Massages et thérapie manuelle</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Étirements et mobilisations articulaires</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Pressothérapie et physiothérapie</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Rééducation périnéale</span>
            </div>
          </div>
        </div>
        <div class="service-detail-visual">
          <svg viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg" class="service-illustration">
            <rect width="400" height="320" rx="16" fill="var(--color-bg-alt)"/>
            <circle cx="200" cy="120" r="60" fill="var(--color-accent)" opacity="0.15"/>
            <circle cx="200" cy="100" r="16" fill="var(--color-primary)" opacity="0.8"/>
            <line x1="200" y1="116" x2="200" y2="170" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <line x1="175" y1="140" x2="225" y2="140" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <line x1="200" y1="170" x2="180" y2="210" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <line x1="200" y1="170" x2="220" y2="210" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <!-- Stretching motion lines -->
            <path d="M240 130 Q260 120 250 100" stroke="var(--color-accent)" stroke-width="2" fill="none" stroke-linecap="round"/>
            <path d="M245 135 Q265 125 255 105" stroke="var(--color-accent)" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.5"/>
            <text x="200" y="270" text-anchor="middle" font-family="Inter, sans-serif" font-weight="600" font-size="14" fill="var(--color-text-light)">Rééducation fonctionnelle</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- OSTÉOPATHIE -->
  <section class="section service-detail alt" id="osteopathie">
    <div class="container">
      <div class="service-detail-grid reverse">
        <div class="service-detail-content">
          <div class="service-number">02</div>
          <h2>Ostéopathie</h2>
          <p class="service-intro">
            L'ostéopathie est une méthode de prise en charge globale qui s'emploie à déterminer et traiter
            les restrictions de mobilité affectant l'ensemble des structures du corps humain.
          </p>
          <div class="service-list">
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Approche globale et personnalisée</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Traitement des douleurs musculo-squelettiques</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Rétablissement de la mobilité articulaire</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Prévention des blessures</span>
            </div>
          </div>
          <div class="service-price">
            <span class="price">60 €</span>
            <span class="price-label">la séance</span>
          </div>
        </div>
        <div class="service-detail-visual">
          <svg viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg" class="service-illustration">
            <rect width="400" height="320" rx="16" fill="var(--color-bg-alt)"/>
            <ellipse cx="200" cy="160" rx="80" ry="90" fill="var(--color-primary)" opacity="0.06"/>
            <!-- Spine illustration -->
            <rect x="192" y="60" width="16" height="22" rx="4" fill="var(--color-primary)" opacity="0.7"/>
            <rect x="190" y="86" width="20" height="24" rx="4" fill="var(--color-primary)" opacity="0.65"/>
            <rect x="188" y="114" width="24" height="26" rx="4" fill="var(--color-primary)" opacity="0.6"/>
            <rect x="186" y="144" width="28" height="26" rx="5" fill="var(--color-primary)" opacity="0.55"/>
            <rect x="184" y="174" width="32" height="28" rx="5" fill="var(--color-primary)" opacity="0.5"/>
            <rect x="186" y="206" width="28" height="26" rx="5" fill="var(--color-primary)" opacity="0.45"/>
            <!-- Hands -->
            <path d="M140 150 Q160 140 175 155" stroke="var(--color-accent)" stroke-width="3" fill="none" stroke-linecap="round"/>
            <path d="M260 150 Q240 140 225 155" stroke="var(--color-accent)" stroke-width="3" fill="none" stroke-linecap="round"/>
            <circle cx="135" cy="150" r="6" fill="var(--color-accent)" opacity="0.6"/>
            <circle cx="265" cy="150" r="6" fill="var(--color-accent)" opacity="0.6"/>
            <text x="200" y="275" text-anchor="middle" font-family="Inter, sans-serif" font-weight="600" font-size="14" fill="var(--color-text-light)">Approche globale du corps</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- PODOLOGIE -->
  <section class="section service-detail" id="podologie">
    <div class="container">
      <div class="service-detail-grid">
        <div class="service-detail-content">
          <div class="service-number">03</div>
          <h2>Podologie</h2>
          <p class="service-intro">
            Le pédicure-podologue du sport est un professionnel de santé spécialisé dans les pathologies
            sportives du pied, du membre inférieur et du rachis.
          </p>
          <div class="service-list">
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Bilan podologique complet</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Semelles orthopédiques sur mesure</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Traitement des pathologies du pied</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Analyse de la posture et de la marche</span>
            </div>
          </div>
        </div>
        <div class="service-detail-visual">
          <svg viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg" class="service-illustration">
            <rect width="400" height="320" rx="16" fill="var(--color-bg-alt)"/>
            <ellipse cx="200" cy="160" rx="100" ry="80" fill="var(--color-accent)" opacity="0.08"/>
            <!-- Foot outline -->
            <path d="M160 100 Q150 140 155 180 Q158 210 170 235 Q185 260 210 260 Q235 255 245 235 Q255 210 250 180 Q248 150 240 120 Q235 100 220 90 Q200 82 180 88 Z" fill="var(--color-primary)" opacity="0.12" stroke="var(--color-primary)" stroke-width="2"/>
            <!-- Toes -->
            <circle cx="175" cy="94" r="8" fill="var(--color-primary)" opacity="0.2"/>
            <circle cx="192" cy="86" r="9" fill="var(--color-primary)" opacity="0.2"/>
            <circle cx="210" cy="84" r="9" fill="var(--color-primary)" opacity="0.2"/>
            <circle cx="226" cy="88" r="8" fill="var(--color-primary)" opacity="0.2"/>
            <circle cx="238" cy="96" r="7" fill="var(--color-primary)" opacity="0.2"/>
            <!-- Insole -->
            <path d="M175 150 Q180 190 185 220 Q195 240 210 240 Q225 235 230 220 Q235 190 232 150" stroke="var(--color-accent)" stroke-width="2.5" fill="none" stroke-dasharray="6 4" stroke-linecap="round"/>
            <text x="200" y="290" text-anchor="middle" font-family="Inter, sans-serif" font-weight="600" font-size="14" fill="var(--color-text-light)">Semelles sur mesure</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- RÉÉDUCATION SPORTIVE -->
  <section class="section service-detail alt" id="reeducation">
    <div class="container">
      <div class="service-detail-grid reverse">
        <div class="service-detail-content">
          <div class="service-number">04</div>
          <h2>Rééducation sportive</h2>
          <p class="service-intro">
            Prise en charge spécifique de la traumatologie sportive, accompagnant le sportif
            de sa blessure récente jusqu'à son retour sur le terrain.
          </p>
          <div class="service-list">
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Protocoles de rééducation post-opératoire</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Renforcement musculaire ciblé</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Balnéothérapie et hydrothérapie</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Cryothérapie et ondes de choc</span>
            </div>
            <div class="service-list-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Retour au sport progressif et encadré</span>
            </div>
          </div>
        </div>
        <div class="service-detail-visual">
          <svg viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg" class="service-illustration">
            <rect width="400" height="320" rx="16" fill="var(--color-bg-alt)"/>
            <!-- Runner figure -->
            <circle cx="180" cy="90" r="14" fill="var(--color-primary)" opacity="0.7"/>
            <line x1="180" y1="104" x2="175" y2="155" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <line x1="160" y1="130" x2="195" y2="120" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <line x1="175" y1="155" x2="155" y2="200" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <line x1="175" y1="155" x2="200" y2="195" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"/>
            <!-- Motion lines -->
            <line x1="220" y1="100" x2="260" y2="100" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
            <line x1="230" y1="115" x2="260" y2="115" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
            <line x1="225" y1="130" x2="250" y2="130" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" opacity="0.3"/>
            <!-- Finish line -->
            <line x1="300" y1="70" x2="300" y2="220" stroke="var(--color-primary)" stroke-width="2" opacity="0.3"/>
            <rect x="290" y="70" width="20" height="15" fill="var(--color-accent)" opacity="0.4"/>
            <rect x="290" y="100" width="20" height="15" fill="var(--color-accent)" opacity="0.4"/>
            <rect x="290" y="130" width="20" height="15" fill="var(--color-accent)" opacity="0.4"/>
            <!-- Arrow -->
            <path d="M270 160 L295 160 L288 150 M295 160 L288 170" stroke="var(--color-primary)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <text x="200" y="270" text-anchor="middle" font-family="Inter, sans-serif" font-weight="600" font-size="14" fill="var(--color-text-light)">Du soin au retour sur le terrain</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-content">
      <h2>Besoin d'un avis professionnel ?</h2>
      <p>Nos praticiens sont à votre écoute pour déterminer le traitement le plus adapté à votre situation.</p>
      <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent">
        Prendre rendez-vous
      </a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 4rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
  }

  .page-hero-content {
    max-width: 640px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(26, 92, 58, 0.08);
    color: var(--color-primary);
    padding: 0.4rem 1.2rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(26, 92, 58, 0.12);
  }

  .page-hero h1 {
    margin-bottom: 1rem;
  }

  .text-accent {
    color: var(--color-primary);
    position: relative;
  }

  .text-accent::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0;
    right: 0;
    height: 8px;
    background: var(--color-accent);
    opacity: 0.3;
    border-radius: 4px;
    z-index: -1;
  }

  .page-hero p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  /* SERVICE DETAIL */
  .service-detail.alt {
    background: var(--color-bg-alt);
  }

  .service-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .service-detail-grid.reverse {
    direction: rtl;
  }

  .service-detail-grid.reverse > * {
    direction: ltr;
  }

  .service-number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-accent);
    opacity: 0.4;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .service-detail-content h2 {
    margin-bottom: 1rem;
  }

  .service-intro {
    color: var(--color-text-light);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .service-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.92rem;
  }

  .service-list-item svg {
    flex-shrink: 0;
  }

  .service-price {
    margin-top: 1.5rem;
    padding: 1rem 1.5rem;
    background: rgba(78, 205, 196, 0.08);
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    border: 1px solid rgba(78, 205, 196, 0.2);
  }

  .price {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .price-label {
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  .service-illustration {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .cta-section {
    background: var(--color-primary);
    padding: 5rem 0;
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto 2rem;
  }

  @media (max-width: 840px) {
    .service-detail-grid,
    .service-detail-grid.reverse {
      grid-template-columns: 1fr;
      gap: 2rem;
      direction: ltr;
    }

    .service-detail-visual {
      order: -1;
    }
  }
</style>
