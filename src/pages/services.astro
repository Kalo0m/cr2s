---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'kinesitherapie',
    num: '01',
    title: 'Kinésithérapie',
    intro: 'La kinésithérapie est un traitement basé sur le mouvement, visant à rétablir les capacités fonctionnelles et améliorer la qualité de vie du patient.',
    items: [
      'Éducation thérapeutique du patient',
      'Exercices actifs et rééducation fonctionnelle',
      'Massages et thérapie manuelle',
      'Étirements et mobilisations articulaires',
      'Pressothérapie et physiothérapie',
      'Rééducation périnéale',
    ],
  },
  {
    id: 'osteopathie',
    num: '02',
    title: 'Ostéopathie',
    intro: "L'ostéopathie est une méthode de prise en charge globale qui s'emploie à déterminer et traiter les restrictions de mobilité affectant l'ensemble des structures du corps humain.",
    items: [
      'Approche globale et personnalisée',
      'Traitement des douleurs musculo-squelettiques',
      'Rétablissement de la mobilité articulaire',
      'Prévention des blessures',
    ],
    price: '60 €',
  },
  {
    id: 'podologie',
    num: '03',
    title: 'Podologie',
    intro: 'Le pédicure-podologue du sport est un professionnel de santé spécialisé dans les pathologies sportives du pied, du membre inférieur et du rachis.',
    items: [
      'Bilan podologique complet',
      'Semelles orthopédiques sur mesure',
      'Traitement des pathologies du pied',
      'Analyse de la posture et de la marche',
    ],
  },
  {
    id: 'reeducation',
    num: '04',
    title: 'Rééducation sportive',
    intro: "Prise en charge spécifique de la traumatologie sportive, accompagnant le sportif de sa blessure récente jusqu'à son retour sur le terrain.",
    items: [
      'Protocoles de rééducation post-opératoire',
      'Renforcement musculaire ciblé',
      'Balnéothérapie et hydrothérapie',
      'Cryothérapie et ondes de choc',
      'Retour au sport progressif et encadré',
    ],
  },
];
---

<Layout title="Services" description="Kinésithérapie, ostéopathie, podologie et rééducation sportive au CR2S Nantes.">
  <section class="page-hero">
    <div class="container">
      <h1>Nos services</h1>
      <p class="page-intro">Une prise en charge complète par notre équipe de kinésithérapeutes, ostéopathes et podologues.</p>
    </div>
  </section>

  {services.map((service, index) => (
    <section class:list={['section', { 'alt-bg': index % 2 === 1 }]} id={service.id}>
      <div class="container">
        <div class="service-content">
          <span class="service-num">{service.num}</span>
          <h2>{service.title}</h2>
          <p class="service-intro">{service.intro}</p>
          <ul class="service-list">
            {service.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
          {service.price && (
            <div class="service-price">
              <span class="price">{service.price}</span>
              <span class="price-label">la séance</span>
            </div>
          )}
        </div>
      </div>
    </section>
  ))}

  <section class="cta-section">
    <div class="container cta-content">
      <h2>Besoin d'un avis professionnel ?</h2>
      <p>Nos praticiens sont à votre écoute pour déterminer le traitement adapté.</p>
      <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent">
        Prendre rendez-vous
      </a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 3.5rem;
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-intro {
    color: var(--color-text-light);
    font-size: 1.05rem;
    max-width: 520px;
  }

  .alt-bg {
    background: var(--color-bg-alt);
  }

  .service-content {
    max-width: 600px;
  }

  .service-num {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .service-content h2 {
    margin-bottom: 0.75rem;
  }

  .service-intro {
    color: var(--color-text-light);
    font-size: 0.92rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .service-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-list li {
    font-size: 0.88rem;
    padding-left: 1rem;
    position: relative;
  }

  .service-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .service-price {
    margin-top: 1.25rem;
    padding: 0.85rem 1.25rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    border: 1px solid var(--color-border);
  }

  .price {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .price-label {
    color: var(--color-text-light);
    font-size: 0.85rem;
  }

  .cta-section {
    background: var(--color-primary);
    padding: 4.5rem 0;
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    color: white;
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.55);
    font-size: 1rem;
    max-width: 480px;
    margin: 0 auto 1.75rem;
  }
</style>
