---
import Layout from '../layouts/Layout.astro';

const equipments = [
  {
    category: 'Balnéothérapie',
    items: ['Piscine 4 x 7 mètres', 'Hydrothérapie', 'Rééducation aquatique'],
    description: 'Notre piscine de 28 m² permet une rééducation en milieu aquatique, idéale pour la reprise en douceur après une blessure.'
  },
  {
    category: 'Musculation & Cardio',
    items: ['Presse', 'Leg extension & leg curl', 'Vélos & stepper', 'Elliptique', 'Tapis de course'],
    description: 'Un plateau technique complet pour le renforcement musculaire et la reprise cardiovasculaire.'
  },
  {
    category: 'Rééducation fonctionnelle',
    items: ['TRX', 'Kettlebell', 'Step', 'Élastiques', 'Matériel fonctionnel', 'Huber'],
    description: 'Équipements pour retrouver stabilité, proprioception et performance.'
  },
  {
    category: 'Technologies',
    items: ['Ondes de choc', 'Cryothérapie', "Appareil d'échographie", 'Électro Kneehab', 'Game Ready'],
    description: 'Technologies de pointe pour accélérer la récupération et optimiser les traitements.'
  },
  {
    category: 'Soins individuels',
    items: ['Salles de thérapie manuelle', 'Mobilisations articulaires', 'Pressothérapie', 'Packs de froid'],
    description: 'Plusieurs salles dédiées : thérapie manuelle, étirements et rééducation périnéale.'
  },
];

const stats = [
  { number: '350 m²', label: 'Surface totale' },
  { number: '85 m²', label: 'Plateau technique' },
  { number: '28 m²', label: 'Piscine' },
  { number: '20+', label: "Ans d'expérience" },
];
---

<Layout title="Équipements" description="Découvrez les équipements et installations du CR2S Nantes.">
  <section class="page-hero">
    <div class="container">
      <span class="tag">Nos installations</span>
      <h1>Un plateau technique d'excellence</h1>
      <p class="page-intro">350 m² d'espace dédié à votre rééducation, équipé des technologies les plus récentes.</p>
    </div>
  </section>

  <section class="section stats-section">
    <div class="container">
      <div class="stats-grid">
        {stats.map(s => (
          <div class="stat-card">
            <span class="stat-number">{s.number}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section equip-section">
    <div class="container">
      <div class="section-header">
        <h2>Nos équipements</h2>
        <p>Des installations modernes au service de votre rééducation</p>
      </div>
      <div class="equip-grid">
        {equipments.map((eq) => (
          <div class="card equip-card">
            <h3>{eq.category}</h3>
            <p class="equip-desc">{eq.description}</p>
            <ul class="equip-list">
              {eq.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-content">
      <h2>Venez découvrir nos installations</h2>
      <p>Au rez-de-chaussée, en plein centre de Nantes, accessible PMR.</p>
      <a href="/contact" class="btn btn-accent">Nous trouver</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 4rem;
    background: var(--color-bg);
  }

  .tag {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  .page-hero h1 { margin-bottom: 1rem; }

  .page-intro {
    color: var(--color-text-light);
    font-size: 1.05rem;
    max-width: 520px;
  }

  .stats-section {
    padding-top: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .stat-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  .equip-section {
    background: var(--color-bg-alt);
  }

  .equip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .equip-card h3 {
    margin-bottom: 0.5rem;
  }

  .equip-desc {
    color: var(--color-text-light);
    font-size: 0.88rem;
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .equip-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .equip-list li {
    font-size: 0.85rem;
    color: var(--color-text);
    padding-left: 1rem;
    position: relative;
  }

  .equip-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .cta-section {
    background: var(--color-primary);
    padding: 5rem 0;
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    color: white;
    margin-bottom: 0.75rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.05rem;
    max-width: 480px;
    margin: 0 auto 2rem;
  }

  @media (max-width: 840px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .stats-grid { grid-template-columns: 1fr; }
    .equip-grid { grid-template-columns: 1fr; }
  }
</style>
