---
import Layout from '../layouts/Layout.astro';

const equipments = [
  {
    category: 'Balnéothérapie',
    items: ['Piscine 4 x 7 mètres', 'Hydrothérapie', 'Rééducation aquatique'],
    description: 'Piscine de 28 m² pour une rééducation en milieu aquatique, idéale pour la reprise en douceur.'
  },
  {
    category: 'Musculation & Cardio',
    items: ['Presse', 'Leg extension & leg curl', 'Vélos & stepper', 'Elliptique', 'Tapis de course'],
    description: 'Plateau technique complet pour le renforcement musculaire et la reprise cardiovasculaire.'
  },
  {
    category: 'Rééducation fonctionnelle',
    items: ['TRX', 'Kettlebell', 'Step', 'Élastiques', 'Matériel fonctionnel', 'Huber'],
    description: 'Équipements pour retrouver stabilité, proprioception et performance.'
  },
  {
    category: 'Technologies',
    items: ['Ondes de choc', 'Cryothérapie', "Appareil d'échographie", 'Électro Kneehab', 'Game Ready'],
    description: 'Technologies de pointe pour accélérer la récupération.'
  },
  {
    category: 'Soins individuels',
    items: ['Salles de thérapie manuelle', 'Mobilisations articulaires', 'Pressothérapie', 'Packs de froid'],
    description: 'Salles dédiées : thérapie manuelle, étirements et rééducation périnéale.'
  },
];
---

<Layout title="Équipements" description="Les équipements et installations du CR2S Nantes.">
  <section class="page-hero">
    <div class="container">
      <h1>Nos équipements</h1>
      <p class="page-intro">350 m² d'espace dédié à votre rééducation, équipé des technologies les plus récentes.</p>
    </div>
  </section>

  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-num">350 m²</span>
          <span class="stat-label">surface totale</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">85 m²</span>
          <span class="stat-label">plateau technique</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">28 m²</span>
          <span class="stat-label">piscine</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">20+</span>
          <span class="stat-label">ans d'expérience</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="equip-grid">
        {equipments.map((eq) => (
          <div class="card equip-card">
            <h3>{eq.category}</h3>
            <p class="equip-desc">{eq.description}</p>
            <ul class="equip-list">
              {eq.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-content">
      <h2>Venez découvrir nos installations</h2>
      <p>Au rez-de-chaussée, en plein centre de Nantes, accessible PMR.</p>
      <a href="/contact" class="btn btn-accent">Nous trouver</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 3.5rem;
  }

  .page-hero h1 { margin-bottom: 0.75rem; }

  .page-intro {
    color: var(--color-text-light);
    font-size: 1.05rem;
    max-width: 480px;
  }

  .stats-section {
    background: var(--color-primary);
    padding: 2.5rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-num {
    font-size: 1.6rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.3rem;
  }

  .equip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .equip-card h3 {
    margin-bottom: 0.4rem;
  }

  .equip-desc {
    color: var(--color-text-light);
    font-size: 0.85rem;
    margin-bottom: 0.85rem;
    line-height: 1.7;
  }

  .equip-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .equip-list li {
    font-size: 0.84rem;
    padding-left: 0.9rem;
    position: relative;
  }

  .equip-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .cta-section {
    background: var(--color-bg-warm);
    padding: 4.5rem 0;
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 1.75rem;
  }

  @media (max-width: 840px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .equip-grid { grid-template-columns: 1fr; }
  }
</style>
