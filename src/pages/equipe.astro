---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    section: 'Kinésithérapeutes',
    description: 'Notre équipe de kinés du sport vous accompagne dans votre rééducation',
    members: [
      'Cédric Lame', 'Nicolas Foucher', 'Maxime Foucher', 'Adrien Couty',
      'Valentin Hulin', 'Julie Philippot', 'Théo Mahé', 'Nina Marion',
      'Louis Landais', 'Cécile Poirier', 'Laurent Richard',
    ],
  },
  {
    section: 'Ostéopathes',
    description: 'Prise en charge globale et personnalisée',
    members: ['Thomas Bizouarn', 'Marion Gauthier Rat'],
  },
  {
    section: 'Podologues',
    description: 'Spécialistes de la podologie du sport',
    members: ['Podologue 1', 'Podologue 2'],
  },
  {
    section: 'Secrétariat',
    description: 'Votre premier contact au centre',
    members: ['Martine', 'Patricia'],
  },
];

function getInitials(name: string) {
  return name.split(' ').map(n => n[0]).join('').toUpperCase();
}
---

<Layout title="Notre équipe" description="Découvrez l'équipe pluridisciplinaire du CR2S Nantes.">
  <section class="page-hero">
    <div class="container">
      <h1>Notre équipe</h1>
      <p class="page-intro">13 praticiens spécialisés dans la rééducation sportive, à votre service du lundi au vendredi.</p>
    </div>
  </section>

  {team.map((group, gi) => (
    <section class:list={['section', { 'alt-bg': gi % 2 === 1 }]}>
      <div class="container">
        <div class="group-header">
          <h2>{group.section}</h2>
          <p>{group.description}</p>
        </div>
        <div class="team-grid">
          {group.members.map((name) => (
            <div class="team-card">
              <div class="team-avatar">
                <span>{getInitials(name)}</span>
              </div>
              <h3>{name}</h3>
              <span class="team-role">{group.section === 'Secrétariat' ? 'Secrétariat' : group.section.slice(0, -1)}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="cta-section">
    <div class="container cta-content">
      <h2>Rencontrez notre équipe</h2>
      <p>Prenez rendez-vous avec le praticien de votre choix.</p>
      <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent">
        Prendre rendez-vous
      </a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 3.5rem;
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-intro {
    color: var(--color-text-light);
    font-size: 1.05rem;
    max-width: 480px;
  }

  .alt-bg {
    background: var(--color-bg-alt);
  }

  .group-header {
    margin-bottom: 2rem;
  }

  .group-header h2 {
    margin-bottom: 0.25rem;
  }

  .group-header p {
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }

  .team-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: 1.5rem 1rem;
    text-align: center;
    border: 1px solid var(--color-border);
    transition: var(--transition);
  }

  .team-card:hover {
    box-shadow: var(--shadow-md);
  }

  .team-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.6rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
  }

  .team-avatar span {
    color: var(--color-text);
    font-weight: 700;
    font-size: 0.8rem;
  }

  .team-card h3 {
    font-size: 0.88rem;
    margin-bottom: 0.1rem;
  }

  .team-role {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .cta-section {
    padding: 5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .cta-content {
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 1.75rem;
  }
</style>
