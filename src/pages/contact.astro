---
import Layout from '../layouts/Layout.astro';

const horaires = [
  { jour: 'Lundi', heures: '08h45 – 12h30 / 13h45 – 18h30' },
  { jour: 'Mardi', heures: '08h45 – 12h30 / 13h45 – 18h30' },
  { jour: 'Mercredi', heures: '08h45 – 12h30 / 13h45 – 18h30' },
  { jour: 'Jeudi', heures: '08h45 – 12h30 / 13h45 – 18h30' },
  { jour: 'Vendredi', heures: '08h45 – 12h30 / 13h45 – 18h30' },
  { jour: 'Samedi', heures: 'Fermé' },
  { jour: 'Dimanche', heures: 'Fermé' },
];
---

<Layout title="Contact" description="Contactez le CR2S Nantes : adresse, horaires, téléphone et prise de rendez-vous.">
  <section class="page-hero">
    <div class="container">
      <span class="tag">Contact</span>
      <h1>Nous trouver</h1>
      <p class="page-intro">En plein centre de Nantes, notre centre vous accueille du lundi au vendredi. Accessible PMR, au rez-de-chaussée.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="info-block">
            <h3>Adresse</h3>
            <p>18 bis, rue Fouré<br/>44000 Nantes</p>
            <span class="info-meta">Rez-de-chaussée, accessible PMR</span>
          </div>

          <div class="info-block">
            <h3>Téléphone</h3>
            <a href="tel:0240890014" class="phone-link">02 40 89 00 14</a>
            <span class="info-meta">Martine et Patricia vous accueillent</span>
          </div>

          <div class="info-block">
            <h3>Rendez-vous en ligne</h3>
            <a href="https://www.maiia.com/cabinet-paramedical/44000-nantes/cr2s-centre-de-reeducation-sport---sante" target="_blank" rel="noopener" class="btn btn-accent rdv-btn">
              Réserver sur Maiia
            </a>
          </div>

          <div class="info-block">
            <h3>Moyens de paiement</h3>
            <p>Espèces, carte bancaire, chèques</p>
          </div>

          <div class="info-block">
            <a href="https://www.google.com/maps/search/?api=1&query=18+bis+rue+Fouré+44000+Nantes" target="_blank" rel="noopener" class="btn btn-outline">
              Ouvrir dans Google Maps
            </a>
          </div>
        </div>

        <div class="hours-section">
          <div class="hours-card">
            <h3>Horaires d'ouverture</h3>
            <div class="hours-table">
              {horaires.map((h) => (
                <div class:list={['hours-row', { closed: h.heures === 'Fermé' }]}>
                  <span class="hours-day">{h.jour}</span>
                  <span class="hours-time">{h.heures}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section access-section">
    <div class="container">
      <div class="section-header">
        <h2>Comment venir</h2>
        <p>Le CR2S est facilement accessible en transport ou en voiture</p>
      </div>
      <div class="grid-3">
        <div class="card access-card">
          <h3>En voiture</h3>
          <p>Parking à proximité. Le centre se situe en plein coeur de Nantes, rue Fouré.</p>
        </div>
        <div class="card access-card">
          <h3>En tramway</h3>
          <p>Arrêts de tramway à proximité, à quelques minutes à pied du centre.</p>
        </div>
        <div class="card access-card">
          <h3>À vélo</h3>
          <p>Stations Bicloo à proximité. Le centre est facilement accessible à vélo.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 8rem 0 4rem;
    background: var(--color-bg);
  }

  .tag {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  .page-hero h1 { margin-bottom: 1rem; }

  .page-intro {
    color: var(--color-text-light);
    font-size: 1.05rem;
    max-width: 520px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .info-block h3 {
    font-size: 0.9rem;
    margin-bottom: 0.35rem;
    letter-spacing: 0;
  }

  .info-block p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .info-meta {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    display: block;
    margin-top: 0.2rem;
  }

  .phone-link {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-primary);
    display: block;
    transition: var(--transition);
  }

  .phone-link:hover {
    color: var(--color-accent);
  }

  .rdv-btn {
    padding: 0.6rem 1.4rem;
    font-size: 0.85rem;
  }

  .hours-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.75rem;
  }

  .hours-card h3 {
    font-size: 1rem;
    margin-bottom: 1.25rem;
  }

  .hours-table {
    display: flex;
    flex-direction: column;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.88rem;
  }

  .hours-row:last-child {
    border-bottom: none;
  }

  .hours-day {
    font-weight: 600;
  }

  .hours-time {
    color: var(--color-text-light);
  }

  .hours-row.closed .hours-time {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .access-section {
    background: var(--color-bg-alt);
  }

  .access-card {
    text-align: center;
  }

  .access-card h3 {
    margin-bottom: 0.5rem;
  }

  .access-card p {
    color: var(--color-text-light);
    font-size: 0.88rem;
  }

  @media (max-width: 840px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
